-- --- LOGIC HITBOX HIỆN ĐẠI (MODERN HITBOX) ---
-- ==========================================================
local HitboxSystem = {}
HitboxSystem.Connection = nil
HitboxSystem.OriginalSizes = {} -- Lưu kích thước gốc để restore

function HitboxSystem.Enable()
    if HitboxSystem.Connection then HitboxSystem.Connection:Disconnect() end
    
    HitboxSystem.Connection = RunService.Heartbeat:Connect(function()
        local size = _G.HitboxSize or 8
        local targets = {}
        
        -- Lấy tool từ Character
        if LocalPlayer.Character then
            for _, v in pairs(LocalPlayer.Character:GetChildren()) do
                if v:IsA("Tool") then table.insert(targets, v) end
            end
        end
        -- Lấy tool từ Backpack
        if LocalPlayer.Backpack then
            for _, v in pairs(LocalPlayer.Backpack:GetChildren()) do
                if v:IsA("Tool") then table.insert(targets, v) end
            end
        end

        for _, tool in pairs(targets) do
            local handle = tool:FindFirstChild("Handle")
            if handle and handle:IsA("BasePart") then
                -- 1. Lưu size gốc nếu chưa lưu
                if not HitboxSystem.OriginalSizes[handle] then
                    HitboxSystem.OriginalSizes[handle] = handle.Size
                end

                -- 2. Thay đổi thuộc tính (Hitbox logic)
                handle.Massless = true
                handle.CanCollide = false
                handle.Size = Vector3.new(size, size, size)
                handle.Transparency = 0.6 

                -- 3. Tạo Visual (Hộp đỏ)
                if not handle:FindFirstChild("HitboxVisual") then
                    local box = Instance.new("SelectionBox")
                    box.Name = "HitboxVisual"
                    box.Adornee = handle
                    box.Color3 = COLOR_RED
                    box.LineThickness = 0.05
                    box.Transparency = 0.6
                    box.Parent = handle
                else
                    -- Cập nhật màu/thuộc tính liên tục phòng trường hợp game reset
                    handle.HitboxVisual.Color3 = COLOR_RED
                end
            end
        end
    end)
end

function HitboxSystem.Disable()
    -- Ngắt kết nối loop
    if HitboxSystem.Connection then
        HitboxSystem.Connection:Disconnect()
        HitboxSystem.Connection = nil
    end

    -- Khôi phục kích thước gốc (Restore)
    for handle, originalSize in pairs(HitboxSystem.OriginalSizes) do
        if handle and handle.Parent then -- Kiểm tra handle còn tồn tại không
            handle.Size = originalSize
            handle.Transparency = 0 -- Reset trong suốt (tùy game, thường là 0)
            
            local vis = handle:FindFirstChild("HitboxVisual")
            if vis then vis:Destroy() end
        end
    end
    
    -- Xóa dữ liệu cũ
    HitboxSystem.OriginalSizes = {}
end

-- Tự động tắt Hitbox khi nhân vật chết để tránh lỗi lưu size
LocalPlayer.CharacterAdded:Connect(function()
    if HitboxSystem.Connection then -- Nếu đang bật thì reset biến lưu, giữ kết nối
        HitboxSystem.OriginalSizes = {}
    end
end)

