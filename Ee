-- --- HIDE PLAYERS & EFFECTS LOGIC ---
local function hidePart(part) if part:IsA("BasePart") then part.Transparency = 1 part.LocalTransparencyModifier = 1 part.CastShadow = false part.CanCollide = false end end

local function hideChar(char)
    if not char then return end
    if hideCharConnections[char] then hideCharConnections[char]:Disconnect() hideCharConnections[char] = nil end
    for _, obj in ipairs(char:GetDescendants()) do 
        if obj:IsA("BasePart") then hidePart(obj) 
        elseif obj:IsA("Decal") then obj.Transparency = 1 
        elseif obj:IsA("Humanoid") then obj.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None 
        elseif obj:IsA("BillboardGui") or obj:IsA("SurfaceGui") then obj.Enabled = false 
        elseif obj:IsA("ParticleEmitter") or obj:IsA("Beam") or obj:IsA("Trail") or obj:IsA("Fire") or obj:IsA("Smoke") or obj:IsA("Sparkles") then
            obj.Enabled = false
        end 
    end
    hideCharConnections[char] = char.DescendantAdded:Connect(function(obj) 
        task.wait() 
        if obj:IsA("BasePart") then hidePart(obj) 
        elseif obj:IsA("Decal") then obj.Transparency = 1 
        elseif obj:IsA("BillboardGui") or obj:IsA("SurfaceGui") then obj.Enabled = false
        elseif obj:IsA("ParticleEmitter") or obj:IsA("Beam") or obj:IsA("Trail") or obj:IsA("Fire") or obj:IsA("Smoke") or obj:IsA("Sparkles") then
            obj.Enabled = false
        end 
    end)
end

local function handlePlayer(plr) if plr == LocalPlayer then return end if plr.Character then plr.Character:WaitForChild("Humanoid", 1) plr.Character:WaitForChild("HumanoidRootPart", 1) task.wait() hideChar(plr.Character) end hidePlayerConnections["Char_" .. plr.UserId] = plr.CharacterAdded:Connect(function(c) c:WaitForChild("Humanoid", 1) c:WaitForChild("HumanoidRootPart", 1) task.wait() hideChar(c) end) end

local function toggleHidePlayers(enable)
    if enable then
        for _, plr in ipairs(LocalPlayers:GetPlayers()) do handlePlayer(plr) end
        hidePlayerConnections.PlayerAdded = LocalPlayers.PlayerAdded:Connect(handlePlayer)
        hidePlayerConnections.PlayerRemoving = LocalPlayers.PlayerRemoving:Connect(function(plr) local key = "Char_" .. plr.UserId if hidePlayerConnections[key] then hidePlayerConnections[key]:Disconnect() hidePlayerConnections[key] = nil end end)
    else
        for k, conn in pairs(hidePlayerConnections) do conn:Disconnect() hidePlayerConnections[k] = nil end
        for char, conn in pairs(hideCharConnections) do conn:Disconnect() hideCharConnections[char] = nil end
        
        for _, plr in ipairs(LocalPlayers:GetPlayers()) do 
            if plr ~= LocalPlayer and plr.Character then 
                for _, obj in ipairs(plr.Character:GetDescendants()) do 
                    if obj:IsA("BasePart") then 
                        if obj.Name == "HumanoidRootPart" then
                            obj.Transparency = 1
                        else
                            obj.Transparency = 0 
                        end
                        obj.LocalTransparencyModifier = 0 
                        obj.CastShadow = true 
                    elseif obj:IsA("Decal") then 
                        obj.Transparency = 0 
                    elseif obj:IsA("BillboardGui") or obj:IsA("SurfaceGui") then 
                        obj.Enabled = true 
                    elseif obj:IsA("ParticleEmitter") or obj:IsA("Beam") or obj:IsA("Trail") or obj:IsA("Fire") or obj:IsA("Smoke") or obj:IsA("Sparkles") then
                        obj.Enabled = true
                    end 
                end 
            end 
        end
    end
end
