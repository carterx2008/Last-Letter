local minSize, maxSize, isDraggingSlider = 2, 50, false
local function updateSliderVisual(sizeValue)
    local percent = (sizeValue - minSize) / (maxSize - minSize)
    if percent < 0 then percent = 0 end if percent > 1 then percent = 1 end
    sliderFill.Size = UDim2.new(percent, 0, 1, 0) sliderBtn.Position = UDim2.new(percent, -7, 0.5, -7) sliderLabel.Text = "Hitbox Size: " .. tostring(math.floor(sizeValue))
end
updateSliderVisual(_G.HitboxSize)
local function updateSliderFromInput(input)
    local sliderX = sliderBg.AbsolutePosition.X
    local sliderWidth = sliderBg.AbsoluteSize.X
    local mouseX = input.Position.X
    local percent = (mouseX - sliderX) / sliderWidth
    if percent < 0 then percent = 0 end if percent > 1 then percent = 1 end
    local newValue = math.floor(minSize + (maxSize - minSize) * percent)
    _G.HitboxSize = newValue
    updateSliderVisual(newValue)
end
