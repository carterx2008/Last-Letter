-- --- TAB LOGIC ---
local activeTabTween = nil
local function switchTab(key)
    if activeTabTween then activeTabTween:Cancel() end
    for tabKey, panel in pairs(tabContainer) do
        local btn = sidebarFrame:FindFirstChild(tabKey .. "Button")
        if btn then
            if tabKey == key then
                panel.Visible = true
                panel.Position = UDim2.new(0, 107, 0, 15) 
                local tweenInfo = TweenInfo.new(0.4, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out)
                activeTabTween = TweenService:Create(panel, tweenInfo, {Position = UDim2.new(0, 107, 0, 0)})
                activeTabTween:Play()
                TweenService:Create(btn, TweenInfo.new(0.3), {BackgroundColor3 = COLOR_ENABLED, TextColor3 = COLOR_TEXT_ACTIVE}):Play()
            else
                panel.Visible = false
                TweenService:Create(btn, TweenInfo.new(0.3), {BackgroundColor3 = COLOR_TAB_INACTIVE, TextColor3 = COLOR_TEXT_INACTIVE}):Play()
            end
        end
    end
end

