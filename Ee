-- ==========================================================
-- --- REAL ID VALIDATION SYSTEM ---
-- ==========================================================
local function validateUser(id)
    local success, name = pcall(function() return LocalPlayers:GetNameFromUserIdAsync(id) end)
    return success and name
end

local function validateGroup(id)
    local success, info = pcall(function() return GroupService:GetGroupInfoAsync(id) end)
    return success and info
end

local function validateProduct(id, infoType)
    local success, info = pcall(function() return MarketplaceService:GetProductInfo(id, infoType) end)
    return success and info
end

local function executeBotting(modeKey, targetId)
    local args = {modeKey, targetId}
    statusLabel.Text = "Sending signal..."
    statusLabel.TextColor3 = COLOR_WARNING
    local success = pcall(function() ReplicatedStorage:WaitForChild("SetBottingMode"):FireServer(unpack(args)) end)
    if success then
        statusLabel.Text = "✓ Active: " .. modeKey .. " (" .. tostring(targetId) .. ")"
        statusLabel.TextColor3 = COLOR_ENABLED
        savedSettings.autoActivate = true
        saveSettings(savedSettings)
    else
        statusLabel.Text = "Error: Server connection failed"
        statusLabel.TextColor3 = COLOR_RED
    end
end

local function processActivation(inputText)
    inputText = inputText:gsub("^%s*(.-)%s*$", "%1") -- Trim space
    if inputText == "" then statusLabel.Text = "Error: Input is empty" statusLabel.TextColor3 = COLOR_RED return end

    local isNumeric = tonumber(inputText) ~= nil
    local finalId = nil
    
    task.spawn(function()
        statusLabel.Text = "Validating existence..."
        statusLabel.TextColor3 = COLOR_SUBTLE_GREY
        
        -- Logic xử lý ID và Username
        if currentMode.Type == "User" then
            if isNumeric then
                finalId = tonumber(inputText)
                if not validateUser(finalId) then
                    statusLabel.Text = "Error: User ID does not exist!" 
                    statusLabel.TextColor3 = COLOR_RED 
                    return 
                end
            else
                -- Convert Name to ID
                statusLabel.Text = "Fetching User ID..."
                local success, result = pcall(function() return ReplicatedStorage:WaitForChild("GetUserIdFromUsername"):InvokeServer(inputText) end)
                if success and result and result ~= 0 then
                    finalId = result
                    -- Double check ID from remote
                    if not validateUser(finalId) then
                        statusLabel.Text = "Error: Fetched ID invalid!" statusLabel.TextColor3 = COLOR_RED return
                    end
                else
                    statusLabel.Text = "Error: Username not found" statusLabel.TextColor3 = COLOR_RED return
                end
            end
        else
            -- Các mode (Group, Asset, Game, Bundle)
            if not isNumeric then
                statusLabel.Text = "Error: Mode requires Numeric ID." statusLabel.TextColor3 = COLOR_RED return
            end
            finalId = tonumber(inputText)
            
            -- CHECK REAL EXISTENCE
            if currentMode.Type == "Group" then
                if not validateGroup(finalId) then statusLabel.Text = "Error: Group ID does not exist!" statusLabel.TextColor3 = COLOR_RED return end
            elseif currentMode.Type == "Asset" then
                if not validateProduct(finalId, Enum.InfoType.Asset) then statusLabel.Text = "Error: Asset/Game ID not found!" statusLabel.TextColor3 = COLOR_RED return end
            elseif currentMode.Type == "Bundle" then
                if not validateProduct(finalId, Enum.InfoType.Bundle) then statusLabel.Text = "Error: Bundle ID not found!" statusLabel.TextColor3 = COLOR_RED return end
            end
        end
        
        -- Nếu vượt qua tất cả validation
        if finalId then executeBotting(currentMode.Key, finalId) end
    end)
end

